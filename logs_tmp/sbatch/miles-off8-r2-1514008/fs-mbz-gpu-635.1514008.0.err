+ '[' 0 = 1 ']'
+ OPTIMIZER_ARGS=(--optimizer adam --lr "${LR}" --lr-decay-style constant --weight-decay 0.1 --adam-beta1 0.9 --adam-beta2 0.98)
+ '[' 0 = 1 ']'
